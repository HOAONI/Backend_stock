model UserBrokerAccount {
  id                  Int                    @id @default(autoincrement())
  userId              Int                    @map("user_id")
  brokerCode          String                 @map("broker_code") @db.VarChar(32)
  providerCode        String                 @default("default") @map("provider_code") @db.VarChar(32)
  providerName        String?                @map("provider_name") @db.VarChar(64)
  environment         BrokerEnvironment      @default(paper)
  accountUid          String                 @map("account_uid") @db.VarChar(128)
  accountDisplayName  String?                @map("account_display_name") @db.VarChar(128)
  credentialCiphertext String                @map("credential_ciphertext")
  credentialIv        String                 @map("credential_iv") @db.VarChar(64)
  credentialTag       String                 @map("credential_tag") @db.VarChar(64)
  status              UserBrokerAccountStatus @default(active)
  isVerified          Boolean                @default(false) @map("is_verified")
  lastVerifiedAt      DateTime?              @map("last_verified_at")
