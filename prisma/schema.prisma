generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnalysisTaskStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum AdminUserStatus {
  active
  disabled
}

enum AdminAuditAction {
  read
  write
}

enum UserBrokerAccountStatus {
  active
  disabled
}

enum BrokerEnvironment {
  paper
  simulation
}

enum SimulationOrderStatus {
  pending
  partial_filled
  filled
  cancelled
}

enum SimulationOrderDirection {
  buy
  sell
}

enum SimulationOrderType {
  limit
  market
}

enum AgentCredentialScope {
  read
  trade
}

model AnalysisHistory {
  id               Int       @id @default(autoincrement())
  ownerUserId      Int?      @map("owner_user_id")
  queryId          String?   @map("query_id") @db.VarChar(64)
  code             String    @db.VarChar(10)
  name             String?   @db.VarChar(50)
  reportType       String?   @map("report_type") @db.VarChar(16)
  sentimentScore   Int?      @map("sentiment_score")
  operationAdvice  String?   @map("operation_advice") @db.VarChar(128)
  trendPrediction  String?   @map("trend_prediction") @db.VarChar(50)
  analysisSummary  String?   @map("analysis_summary")
  rawResult        String?   @map("raw_result")
  newsContent      String?   @map("news_content")
  contextSnapshot  String?   @map("context_snapshot")
  idealBuy         Float?    @map("ideal_buy")
  secondaryBuy     Float?    @map("secondary_buy")
  stopLoss         Float?    @map("stop_loss")
  takeProfit       Float?    @map("take_profit")
  createdAt        DateTime  @default(now()) @map("created_at")

  backtestResults  BacktestResult[]
  ownerUser        AdminUser? @relation("AnalysisHistoryOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([queryId], map: "ix_analysis_history_query_id")
  @@index([code, createdAt], map: "ix_analysis_code_time")
  @@index([ownerUserId, createdAt], map: "ix_analysis_history_owner_created")
  @@map("analysis_history")
}

model NewsIntel {
  id                 Int       @id @default(autoincrement())
  ownerUserId        Int?      @map("owner_user_id")
  queryId            String?   @map("query_id") @db.VarChar(64)
  code               String    @db.VarChar(10)
  name               String?   @db.VarChar(50)
  dimension          String?   @db.VarChar(32)
  query              String?   @db.VarChar(255)
  provider           String?   @db.VarChar(32)
  title              String    @db.VarChar(300)
  snippet            String?
  url                String    @unique(map: "uix_news_url") @db.VarChar(1000)
  source             String?   @db.VarChar(100)
  publishedDate      DateTime? @map("published_date")
  fetchedAt          DateTime  @default(now()) @map("fetched_at")
  querySource        String?   @map("query_source") @db.VarChar(32)
  requesterPlatform  String?   @map("requester_platform") @db.VarChar(20)
  requesterUserId    String?   @map("requester_user_id") @db.VarChar(64)
  requesterUserName  String?   @map("requester_user_name") @db.VarChar(64)
  requesterChatId    String?   @map("requester_chat_id") @db.VarChar(64)
  requesterMessageId String?   @map("requester_message_id") @db.VarChar(64)
  requesterQuery     String?   @map("requester_query") @db.VarChar(255)
  ownerUser          AdminUser? @relation("NewsIntelOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([queryId], map: "ix_news_query_id")
  @@index([code, publishedDate], map: "ix_news_code_pub")
  @@index([fetchedAt], map: "ix_news_fetched_at")
  @@index([ownerUserId, fetchedAt], map: "ix_news_owner_fetched_at")
  @@map("news_intel")
}

model BacktestResult {
  id                  Int       @id @default(autoincrement())
  ownerUserId         Int?      @map("owner_user_id")
  analysisHistoryId   Int       @map("analysis_history_id")
  code                String    @db.VarChar(10)
  analysisDate        DateTime? @map("analysis_date") @db.Date
  evalWindowDays      Int       @default(10) @map("eval_window_days")
  engineVersion       String    @default("v1") @map("engine_version") @db.VarChar(16)
  evalStatus          String    @default("pending") @map("eval_status") @db.VarChar(32)
  evaluatedAt         DateTime  @default(now()) @map("evaluated_at")
  operationAdvice     String?   @map("operation_advice") @db.VarChar(128)
  positionRecommendation String? @map("position_recommendation") @db.VarChar(8)
  startPrice          Float?    @map("start_price")
  endClose            Float?    @map("end_close")
  maxHigh             Float?    @map("max_high")
  minLow              Float?    @map("min_low")
  stockReturnPct      Float?    @map("stock_return_pct")
  directionExpected   String?   @map("direction_expected") @db.VarChar(16)
  directionCorrect    Boolean?  @map("direction_correct")
  outcome             String?   @db.VarChar(16)
  stopLoss            Float?    @map("stop_loss")
  takeProfit          Float?    @map("take_profit")
  hitStopLoss         Boolean?  @map("hit_stop_loss")
  hitTakeProfit       Boolean?  @map("hit_take_profit")
  firstHit            String?   @map("first_hit") @db.VarChar(16)
  firstHitDate        DateTime? @map("first_hit_date") @db.Date
  firstHitTradingDays Int?      @map("first_hit_trading_days")
  simulatedEntryPrice Float?    @map("simulated_entry_price")
  simulatedExitPrice  Float?    @map("simulated_exit_price")
  simulatedExitReason String?   @map("simulated_exit_reason") @db.VarChar(24)
  simulatedReturnPct  Float?    @map("simulated_return_pct")

  analysisHistory     AnalysisHistory @relation(fields: [analysisHistoryId], references: [id], onDelete: Cascade)
  ownerUser           AdminUser? @relation("BacktestResultOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@unique([analysisHistoryId, evalWindowDays, engineVersion], map: "uix_backtest_analysis_window_version")
  @@index([code, analysisDate], map: "ix_backtest_code_date")
  @@index([evaluatedAt], map: "ix_backtest_evaluated_at")
  @@index([ownerUserId, evaluatedAt], map: "ix_backtest_results_owner_evaluated")
  @@map("backtest_results")
}

model BacktestSummary {
  id                   Int       @id @default(autoincrement())
  ownerUserId          Int?      @map("owner_user_id")
  scope                String    @db.VarChar(16)
  code                 String?   @db.VarChar(16)
  evalWindowDays       Int       @default(10) @map("eval_window_days")
  engineVersion        String    @default("v1") @map("engine_version") @db.VarChar(16)
  computedAt           DateTime  @default(now()) @map("computed_at")
  totalEvaluations     Int       @default(0) @map("total_evaluations")
  completedCount       Int       @default(0) @map("completed_count")
  insufficientCount    Int       @default(0) @map("insufficient_count")
  longCount            Int       @default(0) @map("long_count")
  cashCount            Int       @default(0) @map("cash_count")
  winCount             Int       @default(0) @map("win_count")
  lossCount            Int       @default(0) @map("loss_count")
  neutralCount         Int       @default(0) @map("neutral_count")
  directionAccuracyPct Float?    @map("direction_accuracy_pct")
  predictionWinRatePct Float?    @map("prediction_win_rate_pct")
  tradeWinRatePct      Float?    @map("trade_win_rate_pct")
  winRatePct           Float?    @map("win_rate_pct")
  neutralRatePct       Float?    @map("neutral_rate_pct")
  avgStockReturnPct    Float?    @map("avg_stock_return_pct")
  avgSimulatedReturnPct Float?   @map("avg_simulated_return_pct")
  stopLossTriggerRate  Float?    @map("stop_loss_trigger_rate")
  takeProfitTriggerRate Float?   @map("take_profit_trigger_rate")
  ambiguousRate        Float?    @map("ambiguous_rate")
  avgDaysToFirstHit    Float?    @map("avg_days_to_first_hit")
  adviceBreakdownJson  String?   @map("advice_breakdown_json")
  diagnosticsJson      String?   @map("diagnostics_json")
  ownerUser            AdminUser? @relation("BacktestSummaryOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@unique([ownerUserId, scope, code, evalWindowDays, engineVersion], map: "uix_backtest_summary_owner_scope_code_window_version")
  @@index([computedAt], map: "ix_backtest_summary_computed_at")
  @@index([ownerUserId, computedAt], map: "ix_backtest_summary_owner_computed")
  @@map("backtest_summaries")
}

model UserBacktestStrategy {
  id            Int       @id @default(autoincrement())
  ownerUserId   Int       @map("owner_user_id")
  name          String    @db.VarChar(64)
  description   String?   @db.VarChar(255)
  templateCode  String    @map("template_code") @db.VarChar(32)
  paramsJson    Json      @map("params_json")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  ownerUser     AdminUser             @relation("UserBacktestStrategyOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  strategyRuns  StrategyBacktestRun[] @relation("StrategyBacktestRunSavedStrategy")

  @@unique([ownerUserId, name], map: "uix_user_backtest_strategies_owner_name")
  @@index([ownerUserId, updatedAt], map: "ix_user_backtest_strategies_owner_updated")
  @@index([ownerUserId, templateCode], map: "ix_user_backtest_strategies_owner_template")
  @@map("user_backtest_strategies")
}

model StrategyBacktestRunGroup {
  id                 Int       @id @default(autoincrement())
  ownerUserId        Int?      @map("owner_user_id")
  code               String    @db.VarChar(16)
  startDate          DateTime  @map("start_date") @db.Date
  endDate            DateTime  @map("end_date") @db.Date
  effectiveStartDate DateTime? @map("effective_start_date") @db.Date
  effectiveEndDate   DateTime? @map("effective_end_date") @db.Date
  engineVersion      String    @default("backtrader_v1") @map("engine_version") @db.VarChar(32)
  createdAt          DateTime  @default(now()) @map("created_at")

  ownerUser          AdminUser?            @relation("StrategyBacktestRunGroupOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  runs               StrategyBacktestRun[]

  @@index([ownerUserId, createdAt], map: "ix_strategy_backtest_group_owner_created")
  @@index([code, startDate, endDate], map: "ix_strategy_backtest_group_code_range")
  @@map("strategy_backtest_run_groups")
}

model StrategyBacktestRun {
  id               Int       @id @default(autoincrement())
  runGroupId       Int       @map("run_group_id")
  savedStrategyId  Int?      @map("saved_strategy_id")
  savedStrategyName String?  @map("saved_strategy_name") @db.VarChar(64)
  strategyCode     String    @map("strategy_code") @db.VarChar(32)
  strategyVersion  String    @default("v1") @map("strategy_version") @db.VarChar(32)
  paramsJson       Json?     @map("params_json")
  metricsJson      Json?     @map("metrics_json")
  benchmarkJson    Json?     @map("benchmark_json")
  createdAt        DateTime  @default(now()) @map("created_at")

  runGroup        StrategyBacktestRunGroup  @relation(fields: [runGroupId], references: [id], onDelete: Cascade)
  savedStrategy   UserBacktestStrategy?     @relation("StrategyBacktestRunSavedStrategy", fields: [savedStrategyId], references: [id], onDelete: SetNull)
  trades          StrategyBacktestTrade[]
  equityPoints    StrategyBacktestEquityPoint[]

  @@index([runGroupId, strategyCode], map: "ix_strategy_backtest_run_group_strategy")
  @@index([savedStrategyId], map: "ix_strategy_backtest_run_saved_strategy")
  @@map("strategy_backtest_runs")
}

model StrategyBacktestTrade {
  id             Int       @id @default(autoincrement())
  runId          Int       @map("run_id")
  entryDate      DateTime? @map("entry_date") @db.Date
  exitDate       DateTime? @map("exit_date") @db.Date
  entryPrice     Float?    @map("entry_price")
  exitPrice      Float?    @map("exit_price")
  qty            Int?
  grossReturnPct Float?    @map("gross_return_pct")
  netReturnPct   Float?    @map("net_return_pct")
  fees           Float?
  exitReason     String?   @map("exit_reason") @db.VarChar(64)
  createdAt      DateTime  @default(now()) @map("created_at")

  run            StrategyBacktestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, entryDate], map: "ix_strategy_backtest_trade_run_entry")
  @@map("strategy_backtest_trades")
}

model StrategyBacktestEquityPoint {
  id              Int       @id @default(autoincrement())
  runId           Int       @map("run_id")
  tradeDate       DateTime  @map("trade_date") @db.Date
  equity          Float
  drawdownPct     Float?    @map("drawdown_pct")
  benchmarkEquity Float?    @map("benchmark_equity")

  run             StrategyBacktestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, tradeDate], map: "ix_strategy_backtest_equity_run_date")
  @@map("strategy_backtest_equity_points")
}

model AgentBacktestRunGroup {
  id                  Int       @id @default(autoincrement())
  ownerUserId         Int?      @map("owner_user_id")
  code                String    @db.VarChar(16)
  startDate           DateTime  @map("start_date") @db.Date
  endDate             DateTime  @map("end_date") @db.Date
  effectiveStartDate  DateTime? @map("effective_start_date") @db.Date
  effectiveEndDate    DateTime? @map("effective_end_date") @db.Date
  engineVersion       String    @default("agent_replay_v1") @map("engine_version") @db.VarChar(32)
  status              String    @default("completed") @db.VarChar(16)
  phase               String    @default("done") @db.VarChar(16)
  requestHash         String    @unique(map: "uix_agent_backtest_request_hash") @map("request_hash") @db.VarChar(128)
  activeResultVersion Int       @default(1) @map("active_result_version")
  latestResultVersion Int       @default(1) @map("latest_result_version")
  progressPct         Int       @default(100) @map("progress_pct")
  message             String?   @db.VarChar(255)
  configJson          Json?     @map("config_json")
  summaryJson         Json?     @map("summary_json")
  diagnosticsJson     Json?     @map("diagnostics_json")
  fastReadyAt         DateTime? @map("fast_ready_at")
  completedAt         DateTime? @map("completed_at")
  errorMessage        String?   @map("error_message")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  ownerUser           AdminUser? @relation("AgentBacktestRunGroupOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  dailySteps          AgentBacktestDailyStep[]
  trades              AgentBacktestTrade[]
  equityPoints        AgentBacktestEquityPoint[]

  @@index([ownerUserId, createdAt], map: "ix_agent_backtest_group_owner_created")
  @@index([status, phase, createdAt], map: "ix_agent_backtest_group_status_phase_created")
  @@index([code, startDate, endDate], map: "ix_agent_backtest_group_code_range")
  @@map("agent_backtest_run_groups")
}

model AgentBacktestDailyStep {
  id                   Int       @id @default(autoincrement())
  runGroupId           Int       @map("run_group_id")
  resultVersion        Int       @default(1) @map("result_version")
  tradeDate            DateTime  @map("trade_date") @db.Date
  decisionSource       String    @map("decision_source") @db.VarChar(32)
  aiUsed               Boolean   @default(false) @map("ai_used")
  dataPayloadJson      Json?     @map("data_payload_json")
  signalPayloadJson    Json?     @map("signal_payload_json")
  riskPayloadJson      Json?     @map("risk_payload_json")
  executionPayloadJson Json?     @map("execution_payload_json")

  runGroup             AgentBacktestRunGroup @relation(fields: [runGroupId], references: [id], onDelete: Cascade)

  @@unique([runGroupId, resultVersion, tradeDate], map: "uix_agent_backtest_step_group_version_day")
  @@index([runGroupId, resultVersion, tradeDate], map: "ix_agent_backtest_step_group_version_day")
  @@map("agent_backtest_daily_steps")
}

model AgentBacktestTrade {
  id             Int       @id @default(autoincrement())
  runGroupId     Int       @map("run_group_id")
  resultVersion  Int       @default(1) @map("result_version")
  entryDate      DateTime? @map("entry_date") @db.Date
  exitDate       DateTime? @map("exit_date") @db.Date
  entryPrice     Float?    @map("entry_price")
  exitPrice      Float?    @map("exit_price")
  qty            Int?
  grossReturnPct Float?    @map("gross_return_pct")
  netReturnPct   Float?    @map("net_return_pct")
  fees           Float?
  exitReason     String?   @map("exit_reason") @db.VarChar(64)

  runGroup       AgentBacktestRunGroup @relation(fields: [runGroupId], references: [id], onDelete: Cascade)

  @@index([runGroupId, resultVersion, entryDate], map: "ix_agent_backtest_trade_group_version_entry")
  @@map("agent_backtest_trades")
}

model AgentBacktestEquityPoint {
  id              Int       @id @default(autoincrement())
  runGroupId      Int       @map("run_group_id")
  resultVersion   Int       @default(1) @map("result_version")
  tradeDate       DateTime  @map("trade_date") @db.Date
  equity          Float
  drawdownPct     Float?    @map("drawdown_pct")
  benchmarkEquity Float?    @map("benchmark_equity")
  positionRatio   Float?    @map("position_ratio")
  cash            Float?

  runGroup        AgentBacktestRunGroup @relation(fields: [runGroupId], references: [id], onDelete: Cascade)

  @@index([runGroupId, resultVersion, tradeDate], map: "ix_agent_backtest_equity_group_version_day")
  @@map("agent_backtest_equity_points")
}

model AgentBacktestSignalSnapshot {
  id                       Int       @id @default(autoincrement())
  ownerUserId              Int?      @map("owner_user_id")
  code                     String    @db.VarChar(16)
  tradeDate                DateTime  @map("trade_date") @db.Date
  signalProfileHash        String    @map("signal_profile_hash") @db.VarChar(128)
  snapshotVersion          Int       @default(1) @map("snapshot_version")
  decisionSource           String    @map("decision_source") @db.VarChar(32)
  llmUsed                  Boolean   @default(false) @map("llm_used")
  confidence               Float?
  factorPayloadJson        Json?     @map("factor_payload_json")
  archivedNewsPayloadJson  Json?     @map("archived_news_payload_json")
  signalPayloadJson        Json?     @map("signal_payload_json")
  aiOverlayJson            Json?     @map("ai_overlay_json")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  ownerUser                AdminUser? @relation("AgentBacktestSignalSnapshotOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@unique([ownerUserId, code, tradeDate, signalProfileHash, snapshotVersion], map: "uix_agent_backtest_signal_owner_code_day_profile_version")
  @@index([ownerUserId, code, tradeDate], map: "ix_agent_backtest_signal_owner_code_day")
  @@map("agent_backtest_signal_snapshots")
}

model AnalysisTask {
  id             Int                @id @default(autoincrement())
  ownerUserId    Int?               @map("owner_user_id")
  taskId         String             @unique @map("task_id") @db.VarChar(64)
  rootTaskId     String?            @map("root_task_id") @db.VarChar(64)
  retryOfTaskId  String?            @map("retry_of_task_id") @db.VarChar(64)
  attemptNo      Int                @default(1) @map("attempt_no")
  priority       Int                @default(100)
  runAfter       DateTime?          @map("run_after")
  cancelledAt    DateTime?          @map("cancelled_at")
  stockCode      String             @map("stock_code") @db.VarChar(16)
  reportType     String             @map("report_type") @default("detailed") @db.VarChar(16)
  status         AnalysisTaskStatus @default(pending)
  progress       Int                @default(0)
  message        String?            @db.VarChar(200)
  resultQueryId  String?            @map("result_query_id") @db.VarChar(64)
  error          String?            @db.VarChar(500)
  requestPayload Json?              @map("request_payload")
  resultPayload  Json?              @map("result_payload")
  createdAt      DateTime           @default(now()) @map("created_at")
  startedAt      DateTime?          @map("started_at")
  completedAt    DateTime?          @map("completed_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  ownerUser      AdminUser?         @relation("AnalysisTaskOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt], map: "ix_analysis_tasks_status_created")
  @@index([status, priority, createdAt], map: "ix_analysis_tasks_status_priority_created")
  @@index([runAfter, status], map: "ix_analysis_tasks_run_after_status")
  @@index([stockCode, status], map: "ix_analysis_tasks_stock_status")
  @@index([ownerUserId, createdAt], map: "ix_analysis_tasks_owner_created")
  @@index([rootTaskId, attemptNo], map: "ix_analysis_tasks_root_attempt")
  @@map("analysis_tasks")
}

model SchedulerWorkerHeartbeat {
  id           Int      @id @default(autoincrement())
  workerName   String   @unique @map("worker_name") @db.VarChar(64)
  workerMode   String   @map("worker_mode") @db.VarChar(16)
  lastSeenAt   DateTime @map("last_seen_at")
  lastTaskId   String?  @map("last_task_id") @db.VarChar(64)
  lastError    String?  @map("last_error") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("scheduler_worker_heartbeats")
}

model SystemConfigItem {
  id           Int      @id @default(autoincrement())
  key          String   @unique @db.VarChar(128)
  value        String   @default("")
  isSensitive  Boolean  @default(false) @map("is_sensitive")
  category     String   @default("uncategorized") @db.VarChar(32)
  dataType     String   @default("string") @map("data_type") @db.VarChar(16)
  uiControl    String   @default("text") @map("ui_control") @db.VarChar(16)
  displayOrder Int      @default(9999) @map("display_order")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([category, displayOrder], map: "ix_system_config_category_order")
  @@map("system_config_items")
}

model SystemConfigRevision {
  id        Int      @id @default(autoincrement())
  version   String   @unique @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_config_revisions")
}

model AdminUser {
  id           Int             @id @default(autoincrement())
  username     String          @unique(map: "uix_admin_users_username") @db.VarChar(64)
  passwordHash String          @map("password_hash")
  displayName  String?         @map("display_name") @db.VarChar(64)
  email        String?         @db.VarChar(128)
  status       AdminUserStatus @default(active)
  isDeleted    Boolean         @default(false) @map("is_deleted")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")
  lastLoginAt  DateTime?       @map("last_login_at")

  sessions  AdminSession[]
  userRoles AdminUserRole[]
  auditLogs AdminAuditLog[]
  profile   AdminUserProfile?
  ownedAnalysisTasks      AnalysisTask[]    @relation("AnalysisTaskOwner")
  ownedAnalysisHistory    AnalysisHistory[] @relation("AnalysisHistoryOwner")
  ownedNews               NewsIntel[]       @relation("NewsIntelOwner")
  ownedBacktestResults    BacktestResult[]  @relation("BacktestResultOwner")
  ownedBacktestSummaries  BacktestSummary[] @relation("BacktestSummaryOwner")
  ownedUserBacktestStrategies UserBacktestStrategy[] @relation("UserBacktestStrategyOwner")
  ownedStrategyBacktestRunGroups StrategyBacktestRunGroup[] @relation("StrategyBacktestRunGroupOwner")
  ownedAgentBacktestRunGroups AgentBacktestRunGroup[] @relation("AgentBacktestRunGroupOwner")
  ownedAgentBacktestSignalSnapshots AgentBacktestSignalSnapshot[] @relation("AgentBacktestSignalSnapshotOwner")
  brokerAccounts          UserBrokerAccount[]
  brokerSnapshotCaches    UserBrokerSnapshotCache[] @relation("BrokerSnapshotCacheUser")
  agentCredentialTickets  AgentCredentialTicket[] @relation("AgentCredentialTicketUser")
  agentExecutionEvents    AgentExecutionEvent[] @relation("AgentExecutionEventUser")
  analysisAutoOrders      AnalysisAutoOrder[] @relation("AnalysisAutoOrderUser")
  simulationPositions     SimulationPosition[]
  simulationOrders        SimulationOrder[]
  simulationTrades        SimulationTrade[]

  @@index([status, isDeleted], map: "ix_admin_users_status_deleted")
  @@map("admin_users")
}

model AdminUserProfile {
  id                        Int      @id @default(autoincrement())
  userId                    Int      @unique @map("user_id")
  simulationAccountName     String   @default("") @map("simulation_account_name") @db.VarChar(128)
