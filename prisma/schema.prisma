  updatedAt           DateTime               @updatedAt @map("updated_at")
  deletedAt           DateTime?              @map("deleted_at")

  user               AdminUser               @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotCaches     UserBrokerSnapshotCache[]
