# Core
NODE_ENV=development
PORT=8002
HOST=0.0.0.0
ENV_FILE=./.env

# PostgreSQL (Homebrew local default, no password)
DATABASE_URL=postgresql://your_macos_username@localhost:5432/backend_stock?schema=public

# Agent integration
AGENT_BASE_URL=http://127.0.0.1:8001
AGENT_SERVICE_AUTH_TOKEN=change_me
# single HTTP request timeout to Agent (recommended 15000~30000)
AGENT_REQUEST_TIMEOUT_MS=30000
# async task bridge polling controls
AGENT_TASK_POLL_INTERVAL_MS=2000
AGENT_TASK_POLL_TIMEOUT_MS=600000
AGENT_TASK_POLL_MAX_RETRIES=3
AGENT_TASK_RETRY_BASE_DELAY_MS=1000
AGENT_CREDENTIAL_TICKET_TTL_SEC=900
AGENT_CREDENTIAL_TICKET_MAX_TTL_SEC=3600

# Broker gateway (for per-user paper trading account sync)
BROKER_GATEWAY_BASE_URL=http://127.0.0.1:8010
BROKER_GATEWAY_TIMEOUT_MS=15000
BROKER_SNAPSHOT_CACHE_TTL_MS=60000
BROKER_SECRET_KEY=

# API behavior
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ALL=false

# Auth
ADMIN_AUTH_ENABLED=false
ADMIN_SELF_REGISTER_ENABLED=true
ADMIN_SESSION_MAX_AGE_HOURS=24
ADMIN_SESSION_SECRET=
TRUST_X_FORWARDED_FOR=false
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=
RUN_WORKER_IN_API=false
PERSONAL_SECRET_KEY=
# true: send user runtime_config to Agent (runtime_config in DB remains masked)
# note: broker-mode task will force-forward runtime_config even if this flag is false
AGENT_FORWARD_RUNTIME_CONFIG=false

# AI (for image extraction)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=

# Backtest
BACKTEST_EVAL_WINDOW_DAYS=10
BACKTEST_MIN_AGE_DAYS=14
BACKTEST_ENGINE_VERSION=v1
BACKTEST_NEUTRAL_BAND_PCT=2.0

# Migration
LEGACY_SQLITE_PATH=/Users/hoaon/Desktop/毕设相关/project/v4/daily_stock_analysis/data/stock_analysis.db
