{
  "name": "backend_stock",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone backend service for Daily Stock Analysis",
  "license": "MIT",
  "packageManager": "pnpm@10.6.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "start:api": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:dev:all": "RUN_WORKER_IN_API=true nest start --watch",
    "start:all": "RUN_WORKER_IN_API=true node dist/src/main.js",
    "start:worker": "node dist/src/worker.js",
    "start:worker:dev": "tsx -r tsconfig-paths/register src/worker.ts",
    "lint": "eslint \"{src,scripts,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:constraints": "tsx -r tsconfig-paths/register scripts/apply-postgres-constraints.ts",
    "db:prepare:runtime": "tsx -r tsconfig-paths/register scripts/prepare-runtime-db.ts",
    "cleanup:legacy-broker-data": "tsx -r tsconfig-paths/register scripts/cleanup-legacy-broker-data.ts",
    "db:init": "bash scripts/db-init.sh",
    "migrate:sqlite": "tsx -r tsconfig-paths/register scripts/migrate-sqlite-to-postgres.ts",
    "contract:compare": "tsx -r tsconfig-paths/register scripts/compare-runtime-contract.ts",
    "validate:e2e:flows": "tsx -r tsconfig-paths/register scripts/validate-e2e-flows.ts",
    "verify:migration": "tsx -r tsconfig-paths/register scripts/verify-migration-counts.ts",
    "gap:validate": "bash scripts/run-gap-validation.sh",
    "backtest:recompute-all": "tsx -r tsconfig-paths/register scripts/backtest-recompute-all.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.11",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/swagger": "^11.0.6",
    "@prisma/client": "^6.4.1",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.1",
    "@nestjs/testing": "^11.0.11",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "better-sqlite3": "^11.8.1",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "prisma": "^6.4.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
